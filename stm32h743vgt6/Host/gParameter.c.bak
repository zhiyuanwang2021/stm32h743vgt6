	dyncycle_halttime.haltatamplitude_time = 0;
	dyncycle_halttime.haltatamplitude_timestamp = 0;
	dyncycle_halttime.haltatminusamplitude_counter = 0;
	dyncycle_halttime.haltatplusamplitude_counter = 0;
	dyncycle_halttime.wave_time = 0;
	
	Posallctrlpara.PosPid.P = 15;
	Posallctrlpara.PosPid.I = 0;
	Posallctrlpara.PosPid.D = 1;
	Posallctrlpara.SpeedPid.P = 0;
	Posallctrlpara.SpeedPid.I = 0;
	Posallctrlpara.SpeedPid.D = 0;
	Posallctrlpara.Ffd.SpeedFFP = 1;
	Posallctrlpara.Ffd.PosDelay = 0;
	Posallctrlpara.Wnd.WndSize = 0.002;
	Posallctrlpara.Wnd.WndTime = 100 ;//ms
	Posallctrlpara.Nominal.Acc = 5;
	Posallctrlpara.Nominal.Speed = 10;
	Posallctrlpara.DefaultAcc = 5;
	Posallctrlpara.MaxSpeed = 50;
	Posallctrlpara.Sft.UpperSft = 1000;
	Posallctrlpara.Sft.LowerStf = -1000;
	Posallctrlpara.WndExt.WndSize = 2;
	Posallctrlpara.WndExt.WndTime = 10;

	Posallctrlpara.PosExtPid.P = 0.5;
	Posallctrlpara.PosExtPid.I = 0;
	Posallctrlpara.PosExtPid.D = 0;
	
	Loadallctrlpara.PosPid.P = 2;
	Loadallctrlpara.PosPid.I = 0;
	Loadallctrlpara.PosPid.D = 0;
	Loadallctrlpara.SpeedPid.P = 0;
	Loadallctrlpara.SpeedPid.I = 0;
	Loadallctrlpara.SpeedPid.D = 0;
	Loadallctrlpara.Ffd.SpeedFFP = 1;
	Loadallctrlpara.Ffd.PosDelay = 0;
	Loadallctrlpara.Wnd.WndSize = 2 ;
	Loadallctrlpara.Wnd.WndTime = 5 ;//ms
	Loadallctrlpara.Nominal.Acc = 2;
	Loadallctrlpara.Nominal.Speed = 10;
	Loadallctrlpara.DefaultAcc = 0.5;
	Loadallctrlpara.MaxSpeed = 2;
	Loadallctrlpara.Sft.UpperSft = 50000;
	Loadallctrlpara.Sft.LowerStf = -50000;
	Loadallctrlpara.WndExt.WndSize = 20;
	Loadallctrlpara.WndExt.WndTime = 10;

	Loadallctrlpara.PosExtPid.P = 0.0001;
	Loadallctrlpara.PosExtPid.I = 0.00005;
	Loadallctrlpara.PosExtPid.D = 0;
	
	
	svAO.pos = 0;
	AL.openloopAO = 0;
	
	OutputPara.Signal = SGINAL_PULSE_SIGN;
	OutputPara.Sign = 0x00;
	OutputPara.MaxValue = 100;
	OutputPara.MinValue = -100;
