void sendata_default_init(void)
{
	SenData[ch0].Sign = 0x00;//pose
	SenData[ch1].Sign = 0x00;//large deformation
	SenData[ch2].Sign = 0x00;//ext1
	SenData[ch3].Sign = 0x00;//ext2
	SenData[ch4].Sign = 0x01;//Load
	
	SenData[ch0].NominalSensitive = 0.0000282462;
	SenData[ch1].NominalSensitive = 1;
	SenData[ch2].NominalSensitive = 1;
	SenData[ch3].NominalSensitive = 1;
	SenData[ch4].NominalSensitive = 2;
}

void commBufResume(commBuf_t* x,commBuf_t* x_last)
{
	memcpy(x,x_last,sizeof(*x));
}

void commBufSave(commBuf_t* x,commBuf_t* x_last)
{
	memcpy(x_last,x,sizeof(*x_last));
}

float constraint(float in,float upperlimit,float lowerlimit)
{	
	float out;
	out = in;
	if(out > upperlimit) out = upperlimit;
	if(out < lowerlimit) out = lowerlimit;
	return out;
}