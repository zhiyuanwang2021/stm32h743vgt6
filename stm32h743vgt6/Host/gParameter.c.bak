	//ЮЛжУБеЛЗПижЦВЮЪ§ГѕЪМЛЏ
	//Pos
	commBuf.Pos.Pid.P = 1;
	commBuf.Pos.Pid.I = 0.01;
	commBuf.Pos.Pid.D = 0.1;
	commBuf.Pos.Pid_Hp.P = 2;
	commBuf.Pos.Pid_Hp.I = 0.02;
