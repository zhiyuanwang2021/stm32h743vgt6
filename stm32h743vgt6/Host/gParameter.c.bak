	AL.loadCtrl.NominalSensitive = 2;

	AL.posCtrl.sign = 1;
	AL.loadCtrl.sign = -1;
	AL.loadCtrl.NominalValue = 50;
	AL.ext1Ctrl.NominalValue = 10;
	AL.ext2Ctrl.NominalValue = 10;
	
	//ВтСПЪ§ОнЩЯБЈжмЦк
