	commBuf.Load.Pid.I = 0.01;
	commBuf.Load.Pid.D = 0;
	commBuf.Load.Pid_Hp.P = 2;
	commBuf.Load.Pid_Hp.I = 0.02;
	commBuf.Load.Pid_Hp.D = 0;
	//Ext
	commBuf.Ext.Pid.P = 2;
	commBuf.Ext.Pid.I = 0.02;
	commBuf.Ext.Pid.D = 0.2;
	commBuf.Ext.Pid_Hp.P = 4;
	commBuf.Ext.Pid_Hp.I = 0.04;
	commBuf.Ext.Pid_Hp.D = 0.4;
	
	//ЫйЖШЧАРЁВЮЪ§ГѕЪМЛЏ
	//Pos
	commBuf.Pos.Ffd.SpeedFFP = 0;
	commBuf.Pos.Ffd.PosDelay = 0;
	commBuf.Pos.Ffd_Hp.SpeedFFP = 0;
	commBuf.Pos.Ffd_Hp.PosDelay = 0;
	//Load
	commBuf.Load.Ffd.SpeedFFP = 2;
	commBuf.Load.Ffd.PosDelay = 20;
	commBuf.Load.Ffd_Hp.SpeedFFP = 4;
	commBuf.Load.Ffd_Hp.PosDelay = 40;
	//Ext
	commBuf.Ext.Ffd.SpeedFFP = 3;
	commBuf.Ext.Ffd.PosDelay = 30;
	commBuf.Ext.Ffd_Hp.SpeedFFP = 6;
	commBuf.Ext.Ffd_Hp.PosDelay = 60;
	
	//ШэЯоЮЛ
	commBuf.Pos.Sft.UpperSft = 1000;
	commBuf.Pos.Sft.LowerStf = -1000;
	commBuf.Load.Sft.UpperSft = 1000;
	commBuf.Load.Sft.LowerStf = -1000;
	commBuf.Ext.Sft.UpperSft = 1000;
	commBuf.Ext.Sft.LowerStf = -1000;
	
	//ЩшЖЈФПБъЮѓВю/ЪБМфДАПк
	commBuf.Pos.Wnd.WndSize = 0.01;
	commBuf.Pos.Wnd.WndTime = 50;
	commBuf.Load.Wnd.WndSize = 1;
	commBuf.Load.Wnd.WndTime = 50;
	commBuf.Ext.Wnd.WndSize = 0.01;
	commBuf.Ext.Wnd.WndTime = 50;
	
	//dyncycle_halttime
