	AL.Load.DefaultDec = -0.5;
	
	AL.Ext.Pid.P = 1;
	AL.Ext.Pid.I = 0;
	AL.Ext.Pid.D = 0;
	
	AL.Pos.Ffd.SpeedFFP = 100;
	
	//ДЋИаЦїТЫВЈГѕЪМЛЏ
