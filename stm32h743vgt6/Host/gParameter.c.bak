	AL.openloopAO = 0;
	
	commBuf.openloopAO = 0;
	
	commBuf.SysPara.TransmitDataPeriod = AL.SysPara.TransmitDataPeriod; //20ms
	
	//БеЛЗПижЦВЮЪ§ГѕЪМЛЏ
	AL.Pos.Pid.P = 1;
	AL.Pos.Pid.I = 0;
	AL.Pos.Pid.D = 1;
	
	AL.Pos.PidSpeed.P = 0.2;
	AL.Pos.PidSpeed.I = 0.1;
	
	AL.Load.Pid.P = 0.05;
	AL.Load.Pid.I = 0;
