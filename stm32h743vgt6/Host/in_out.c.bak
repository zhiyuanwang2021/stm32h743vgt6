void inputGetValue()
{
	//Encoder
	Encoder_Get(Encoder0,&encoder);
	//AI 在外部中断中获取
	ADS1274_Data_Process(&ads1274_par);
	//DI
	DIDetect_ReadALL();
	//DB9
	DB9Detect_ReadALL();

}

void inputMapping()
{
	uint32_t ls_filter_len = 50;
	//DI ordinary IO mapping 
	DI_map(&halDI);
	//DI function map
	//DIMap[1].func(DI.DI2);
	//Servo mapping
	ServoIO_map(&halDI);
	//DB9 ordinary IO mapping 
	DB9_map(&halDB9);
	//CON ADJ monitor
	sensorCON_ADJ_Monitor(&DB9);
	//measure data code value mapping
	MD_CODE_map(&ads1274_par,&encoder,sensorCheck.MapNum);
	//sensor settare monitor
	SetTareMonitor(&AL);
	//pose calculate
	pose_calculate();
	//pose speed filter
	posespeed_filter(5);
	//load calculate
	load_calculate(&force,&AL);
	//load filter
	load_lsm_filter(ls_filter_len);

	fliterLen.Len = sigmodLen(3,(double)(ls_slide_t.k/10.0),FILTER_LEN);
	load_filter_SL(fliterLen.Len); 
	/**************************************************************************************************
	//load_filter(1); 
	//load speed filter
	//loadspeed_filter(10);
	//x-pos y-load least square fast method
	//ls_slide_t.x_m = mean_fast(ls_filter_len,&ls_slide_t.i_xm,&ls_slide_t.x_mtemp,ls_slide_t.x_mbuf,++ls_slide_t.n);
	***************************************************************************************************/
	//pos generator update if sendata is updated
	sendata_pg_process();

}

void outputMapping()
{
	//openloop mapping
	if(stateFlag.openloop == 1) //OPENLOOP
		openloopOutputMap(&OutputPara);
	//closeloop maping
	else
		closeloopOutputMap(&OutputPara);
	//emergency scram button process (use for testing)
	emergency_scram_button_process();
}

void outputControl()
{

	//Pulse ouput
	Servo_mod_fclk(PULSE,hal_output.PWM);
	hal_output.PWM_last = hal_output.PWM;
	//PWM start enable 
	Servo_PWM_Enable(PULSE);
	//DAC output
	DAC8831_Write(hal_output.AO);
	//SRV DIR
	(hal_output.DO.DIR == 1) ? DIR_SET :DIR_RESET;
	//SRV ENBALE
	(hal_output.DO.SON == 1) ? SRV_ON :SRV_OFF;
	
	//SRV_ON;
	//SRV DIR
	// if(hal_output.PWM < 0)
	// {
	// 	dir = hal_output.DO >> 1;
	// 	dir = (~dir)&0x01; 
	// }
	// if(dir == 1) 
	// 	DIR_SET;
	// else 
	// 	DIR_RESET;
	//Darlington
	Darlington_Write(P_DO1_Pin,hal_output.DO.DO1);
	Darlington_Write(P_DO2_Pin,hal_output.DO.DO2);
	Darlington_Write(P_DO3_Pin,hal_output.DO.DO3);
	//Relay
	Relay_Write(P_DO4_RL_Pin,hal_output.DO.DO4_RL);
	Relay_Write(P_DO5_RL_Pin,hal_output.DO.DO5_RL);
}

/**
 * @brief ADC CODE map
 * @param[in] par ADS1274 sample value 
 * @param[in] encdr encoder struct
*/
void MD_CODE_map(ADS1274_PAR *par,ENCODER_STRUCT *encdr,uint8_t SensorMapNum[3]){
	if(SensorMapNum[0] == SENSOR_NO_CHANNEL)
		force.code 		 		= AL.tare.value[4];
	else
		force.code 		 		= par->value[SensorMapNum[0]];
	if(SensorMapNum[1] == SENSOR_NO_CHANNEL) 
		strain1.code 		 	= 0;
	else
		strain1.code			= par->value[SensorMapNum[1]];
	if(SensorMapNum[2] == SENSOR_NO_CHANNEL)
		strain2.code 		 	= 0;
	else
		strain2.code			= par->value[SensorMapNum[2]];

	pose.code 				= encdr->count0;
}

