	DI.DI4.timPress = x->DI4.pressTime;
	DI.DI4.timUnPress = x->DI4.unpressTime;
	DI.DI5.value = x->DI5.value;
	DI.DI5.timPress = x->DI5.pressTime;
	DI.DI5.timUnPress = x->DI5.unpressTime;
