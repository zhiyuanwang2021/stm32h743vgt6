typedef struct 
{ 
 float 		MaxExcitation; 		/* Maximum excitation voltage [V] 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾑｹ*/
 uint16_t 	MinImpedance; 		/* Impedance [Ohm] 魹ｽ魹ｽﾐ｡魹ｽ霑ｹ*/
 float 		NominalValue; 		/* Nominal value of the sensor [Unit] 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾖｵ*/
 uint16_t 	Unit; 				/* Unit of sensor UNIT_xxx [No] 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾎｻ*/
 float 		Offset; 			/* Sensor offset [Unit] 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾆｫ魹ｽ魹ｽ魹ｽ魹ｽ*/
 uint16_t 	NegLimit; 			/* Range limit - min. [%] 魹ｽﾞｷ魹ｽ 魹ｽ魹ｽﾐ｡ﾖｵ %*/
 uint16_t 	PosLimit; 			/* Range limit - max. [%] 魹ｽﾞｷ魹ｽ 魹ｽ魹ｽ魹ｽﾖｵ %*/
 float 		Reference; 			/* Nominal value of the reference [*] 魹ｽﾎｿ魹ｽﾖｵ魹ｽﾄｱ魹ｽ魹ｽﾖｵ*/
 float 		CorrReference;		/* Corr. value of the reference [No]魹ｽﾎｿ魹ｽﾖｵ魹ｽ魹ｽﾐ｣魹ｽ魹ｽﾖｵ*/
 uint16_t 	Sensortype; 		/* Sensor type 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ*/
 float 		NominalSensitive; 	/* Sensitivity at Nominal value [*] 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ*/
 uint16_t   GaugeLength;		/* Gauge Length [*] 魹ｽ魹ｽ魹ｽ魹ｽﾆｱ魹ｽ魹ｽ*/
 uint16_t 	Sign; 				/* Invert sign of channel [1/0] ﾍｨ魹ｽ魹ｽ魹ｽﾄｷ魹ｽ魹ｽﾅｷ魹ｽﾗｪ*/
 uint16_t 	Day; 				/* Date of last change [No] 魹ｽﾏｴﾎｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾚｵ魹ｽ魹ｽ魹ｽ*/
 uint16_t 	Month; 				/* Date of last change [No]	魹ｽﾏｴﾎｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾚｵ魹ｽ魹ｽ魹ｽ*/
 uint16_t 	Year; 				/* Date of last change [No]	魹ｽﾏｴﾎｸ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾚｵ魹ｽ魹ｽ魹ｽ*/
 uint16_t 	LinPoint; 			/* Number of linearization steps [No] 魹ｽ魹ｽ魹ｽﾔｻ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ*/
 struct LinVal2
 {
 float MeasValue; 				/* Measured value [Unit] 魹ｽ魹ｽ魹ｽ魹ｽﾖｵ*/
 float RefValue; 				/* Reference [Unit] 魹ｽﾎｿ魹ｽﾖｵ*/
 } LinV2[SEN_LIN_DATA_MAX]; 		/* Linearization table 魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽﾔｻ魹ｽ魹ｽ魹ｽ魹ｽ魹ｽ*/
}SENSORANALOGUEDATA;

